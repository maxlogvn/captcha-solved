{
  "name": "playwright-geetest-plugin",
  "version": "1.0.0",
  "description": "GeeTest Slider Captcha Solver for Playwright/Patchright",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "demo": "tsx demo.ts",
    "run-test": "tsx tests/index.ts"
  },
  "keywords": [
    "playwright",
    "patchright",
    "captcha",
    "geetest",
    "slider"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "node-fetch": "^3.3.2",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "fingerprint-chromium-engine": "github:maxlogvn/finger-chromium",
    "playwright-core": "^1.60.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
